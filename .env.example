# Example .env file for arXiv Daily Feishu

# 飞书 Webhook URL，用于发送通知
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# 代理设置（可选）
HTTP_PROXY=http://your-proxy-url:port
HTTPS_PROXY=https://your-proxy-url:port

# 日志级别（可选，默认 INFO）
LOG_LEVEL=INFO

# OpenAI 兼容接口配置
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# arXiv 抓取配置
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CV,cs.LG
ARXIV_HOURS=25
MAX_PAPERS=30
ARXIV_REQUEST_DELAY=3.0
ARXIV_HTTP_TIMEOUT=90

# 仔细阅读（基于 arXiv 官方 HTML 全文）
ARXIV_FETCH_HTML_FULLTEXT=true
ARXIV_FULLTEXT_CONTEXT_MAX_CHARS=16000
ARXIV_HTML_FETCH_TIMEOUT=40

# LLM 调用
LLM_TIMEOUT=120
LLM_MAX_CONCURRENT=4